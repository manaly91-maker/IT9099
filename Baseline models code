      "cell_type": "code",
      "source": [
        "# --- Model 1: TF-IDF + Logistic Regression ---\n",
        "print(\"\\n\" + \"-\" * 80)\n",
        "print(\"MODEL 1: TF-IDF + LOGISTIC REGRESSION\")\n",
